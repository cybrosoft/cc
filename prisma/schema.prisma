// prisma/schema.prisma

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum Role {
  ADMIN
  STAFF
  CUSTOMER
}

enum ProductType {
  plan
  addon
  service
  product
}

enum TemplateStatus {
  active
  inactive
  coming_soon
}

enum TemplateIconType {
  devicon
  upload
}

enum LocationStatus {
  active
  inactive
  coming_soon
}

// Replaces BillingMode — supported billing periods per product
enum BillingPeriod {
  MONTHLY
  SIX_MONTHS
  YEARLY
  ONE_TIME
}

enum AddonPricingType {
  fixed
  percentage
  per_unit
}

enum AddonBehavior {
  optional
  required
}

enum BillingProvider {
  ZOHO
  MANUAL
}

enum SubscriptionStatus {
  PENDING_PAYMENT
  PENDING_EXTERNAL
  ACTIVE
  CANCELED
}

enum PaymentStatus {
  UNPAID
  PAID
  FAILED
}

enum AccountType {
  BUSINESS
  PERSONAL
}

//////////////////////////////////////////////////////
// CORE BUSINESS MODELS
//////////////////////////////////////////////////////

model Market {
  id              String          @id @default(cuid())
  key             String          @unique
  name            String
  defaultCurrency String
  zohoOrgId       String?
  billingProvider BillingProvider @default(MANUAL)
  isActive        Boolean         @default(true)

  users                    User[]
  subscriptions            Subscription[]
  pricing                  Pricing[]
  customerPricingOverrides CustomerPricingOverride[]
  pendingSignups           PendingSignup[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
  @@index([isActive])
}

model CustomerGroup {
  id       String  @id @default(cuid())
  key      String  @unique
  name     String
  isActive Boolean @default(true)

  users   User[]
  pricing Pricing[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([key])
}

model User {
  id             String @id @default(cuid())
  customerNumber Int    @unique @default(autoincrement())
  email          String @unique
  role           Role   @default(CUSTOMER)

  marketId String
  market   Market @relation(fields: [marketId], references: [id], onDelete: Restrict)

  customerGroupId String?
  customerGroup   CustomerGroup? @relation(fields: [customerGroupId], references: [id], onDelete: SetNull)

  fullName    String?
  mobile      String?
  accountType AccountType?

  country  String?
  province String?

  companyName                  String?
  vatTaxId                     String?
  commercialRegistrationNumber String?

  addressLine1 String?
  addressLine2 String?
  district     String?
  city         String?
  tags Tag[]   // many-to-many (implicit) — customer tags

  tcAccepted        Boolean?
  privacyAccepted   Boolean?
  marketingAccepted Boolean?

  sessions Session[]

  subscriptions         Subscription[]
  approvedSubscriptions Subscription[] @relation("SubscriptionApprovedBy")

  servers Server[]

  auditLogs AuditLog[]

  customerPricingOverrides CustomerPricingOverride[]

  notePublic  String? @db.Text
  notePrivate String? @db.Text

  createdAt DateTime @default(now())

  @@index([marketId])
  @@index([customerGroupId])
  @@index([role])
}

model PendingSignup {
  id    String @id @default(cuid())
  email String @unique

  marketId String
  market   Market @relation(fields: [marketId], references: [id], onDelete: Cascade)

  fullName    String?
  mobile      String?
  accountType AccountType?

  country  String?
  province String?

  companyName                  String?
  vatTaxId                     String?
  commercialRegistrationNumber String?

  addressLine1 String?
  addressLine2 String?
  district     String?
  city         String?

  tcAccepted        Boolean?
  privacyAccepted   Boolean?
  marketingAccepted Boolean?

  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expiresAt])
  @@index([marketId])
}

model LoginOtp {
  id           String    @id @default(cuid())
  email        String
  codeHash     String
  expiresAt    DateTime
  consumedAt   DateTime?
  attemptCount Int

  createdAt DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
}

model Session {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  token String @unique

  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Category {
  id       String  @id @default(cuid())
  key      String  @unique
  name     String
  isActive Boolean @default(true)

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// New model — add after the Tag model (or any other model)
model OsTemplate {
  id          String           @id @default(cuid())
  slug        String           @unique
  name        String           // version/template name e.g. "22.04 LTS"
  family      String?          // group name e.g. "Ubuntu" — null = standalone
  description String?
  category    String           // "OS" | "App"
  iconType    TemplateIconType @default(devicon)
  iconValue   String?          // devicon class string OR uploaded file URL/path
  status      TemplateStatus   @default(active)
  sortOrder   Int              @default(1)
  isDefault   Boolean          @default(false)
  tagKeys     String[]         // e.g. ["linux","vps"] — OR matched vs product tags

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([family])
  @@index([category])
}

model Location {
  id          String         @id @default(cuid())
  code        String         @unique   // e.g. "JED", "FRA"
  name        String                   // city name e.g. "Jeddah"
  family      String?                  // country/region e.g. "Saudi Arabia"
  description String?
  countryCode String?                  // ISO 2-letter e.g. "SA"
  flag        String?                  // flag emoji e.g. "🇸🇦"
  status      LocationStatus @default(active)
  sortOrder   Int            @default(1)
  isDefault   Boolean        @default(false)
  includeTags String[]       // products with ANY of these tags appear here
  excludeTags String[]       // products with ANY of these tags are hidden

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([family])
}

model Product {
  id       String      @id @default(cuid())
  type     ProductType
  key      String      @unique
  name     String
  isActive Boolean     @default(true)

  // Billing periods available for this product — customer picks one at checkout
  // Replaces the old billingMode + introMonths fields
  billingPeriods BillingPeriod[]
  unitLabel  String?   // e.g. "mailbox", "GB", "seat" — for metered plans only

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  zohoPlanId String?

  tags                     Tag[]                     // many-to-many (implicit)

  pricing                  Pricing[]
  subscriptions            Subscription[]
  customerPricingOverrides CustomerPricingOverride[]

  addonPricingType  AddonPricingType? // fixed | percentage | per_unit
  addonBehavior     AddonBehavior?    // optional | required
  applicableTags    String[]          // plan tag keys this addon appears for
  addonUnitLabel    String?           // e.g. "GB", "IP" — for per_unit only
  addonMinUnits     Int?              // minimum quantity — for per_unit only
  addonMaxUnits     Int?              // maximum quantity — for per_unit only
  addonPercentage   Decimal?          // e.g. 20.00 — for percentage only

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([categoryId])
  @@index([isActive])
}

// One row per Product × Market × CustomerGroup × BillingPeriod
// Empty = product not visible to that group in that market
model Pricing {
  id String @id @default(cuid())

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  marketId String
  market   Market @relation(fields: [marketId], references: [id], onDelete: Cascade)

  customerGroupId String
  customerGroup   CustomerGroup @relation(fields: [customerGroupId], references: [id], onDelete: Cascade)

  billingPeriod BillingPeriod

  // Price in smallest currency unit (halalas for SAR, cents for USD)
  priceCents Int
  isActive   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, marketId, customerGroupId, billingPeriod])
  @@index([productId])
  @@index([marketId])
  @@index([customerGroupId])
  @@index([isActive])
}

// Enterprise per-customer fixed price overrides
// When set, this price is used instead of the group Pricing row
model CustomerPricingOverride {
  id String @id @default(cuid())

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  marketId String
  market   Market @relation(fields: [marketId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  billingPeriod BillingPeriod

  priceCents Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, marketId, userId, billingPeriod])
  @@index([productId])
  @@index([userId])
  @@index([marketId])
}

model Subscription {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  marketId String
  market   Market @relation(fields: [marketId], references: [id], onDelete: Restrict)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity   Int?      // null = not metered; set for metered plan subscriptions
  templateSlug  String?
  locationCode  String?

  status SubscriptionStatus @default(PENDING_PAYMENT)

  parentSubscriptionId String?
  parentSubscription   Subscription?  @relation("AddonParent", fields: [parentSubscriptionId], references: [id], onDelete: SetNull)
  childSubscriptions   Subscription[] @relation("AddonParent")

  // The billing period the customer chose at checkout
  billingPeriod BillingPeriod @default(YEARLY)
  paymentStatus PaymentStatus @default(UNPAID)

  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?

  invoiceNumber          String?
  receiptUrl             String?
  receiptFileName        String?
  receiptUploadedAt      DateTime?
  manualPaymentReference String?

  productDetails String?
  productNote    String?

  approvedByUserId String?
  approvedBy       User?   @relation("SubscriptionApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)

  zohoSubscriptionId String?

  servers Server[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([marketId])
  @@index([productId])
  @@index([parentSubscriptionId])
  @@index([approvedByUserId])
}

model Server {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  subscriptionId String?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  hetznerServerId String? @unique
  hetznerApiToken String?

  oracleInstanceId       String?  @unique
  oracleInstanceRegion   String?
  oracleCompartmentOcid  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([subscriptionId])
}

model AuditLog {
  id          String @id @default(cuid())
  actorUserId String
  actor       User   @relation(fields: [actorUserId], references: [id], onDelete: Cascade)

  action       String
  entityType   String
  entityId     String
  metadataJson String?

  createdAt DateTime @default(now())

  @@index([actorUserId])
  @@index([entityType, entityId])
}

//////////////////////////////////////////////////////
// TAG
//////////////////////////////////////////////////////

model Tag {
  id   String @id @default(cuid())
  key  String @unique  // e.g. "windows", "linux"
  name String          // e.g. "Windows", "Linux"

  products Product[]   // many-to-many (implicit)
  users    User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}
