// prisma/schema.prisma
// Step 4: Added new models (SalesDocument, SalesDocumentLine, Payment,
//         Notification, PortalPage, PortalSetting, NumberSeries)
//         + new fields on Product (nameAr, detailsAr, productDetails)
//         + new fields on Category (nameAr)
//         + new fields on Market (vatPercent, legalInfo, companyProfile, paymentMethods)

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum Role {
  ADMIN
  STAFF
  CUSTOMER
}

enum ProductType {
  plan
  addon
  service
  product
}

enum TemplateStatus {
  active
  inactive
  coming_soon
}

enum TemplateIconType {
  devicon
  upload
}

enum LocationStatus {
  active
  inactive
  coming_soon
}

enum BillingPeriod {
  MONTHLY
  SIX_MONTHS
  YEARLY
  ONE_TIME
}

enum AddonPricingType {
  fixed
  percentage
  per_unit
}

enum AddonBehavior {
  optional
  required
}

enum BillingProvider {
  ZOHO
  MANUAL
}

enum SubscriptionStatus {
  PENDING_PAYMENT
  PROCESSING        // was PENDING_EXTERNAL — manual or Stripe/Zoho triggered
  ACTIVE
  SUSPENDED         // auto after 15 days unpaid, or manual
  EXPIRED           // auto when currentPeriodEnd passes
  CANCELED          // auto 30 days after EXPIRED, or manual
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  FAILED
}

enum AccountType {
  BUSINESS
  PERSONAL
}

// ── NEW Step 4 Enums ──────────────────────────────────────────────────────────

enum SalesDocumentType {
  RFQ
  QUOTATION
  PO
  DELIVERY_NOTE
  PROFORMA
  INVOICE
  CREDIT_NOTE
}

enum SalesDocumentStatus {
  // Shared
  DRAFT
  ISSUED
  SENT
  CONVERTED
  VOID

  // RFQ
  PENDING      // submitted by customer, awaiting review
  IN_REVIEW    // admin is actively reviewing
  QUOTED       // admin responded with a quotation
  CLOSED       // closed without action
  FOLLOW_UP

  // Quotation
  REVISED      // quote was revised after sending
  ACCEPTED     // customer accepted
  REJECTED     // customer declined
  EXPIRED      // validity period passed (cron or manual)

  // PO
  PROCESSING   // PO being fulfilled

  // Delivery Note
  DELIVERED    // confirmed received
  CANCELLED    // delivery cancelled or failed

  // Invoice
  PARTIALLY_PAID  // partial payment recorded (auto)
  PAID            // fully paid (auto)
  OVERDUE         // due date passed, unpaid (cron)
  WRITTEN_OFF     // bad debt — admin only, customer sees OVERDUE

  // Credit Note
  APPLIED      // credit applied against invoice or refunded
}

enum PaymentMethod {
  BANK_TRANSFER
  STRIPE
  CASH
  OTHER
}

enum NotificationType {
  INFO
  WARNING
  ERROR
  SUCCESS
}

//////////////////////////////////////////////////////
// CORE MODELS
//////////////////////////////////////////////////////

model Market {
  id              String          @id @default(cuid())
  key             String          @unique
  name            String
  defaultCurrency String
  zohoOrgId       String?
  billingProvider BillingProvider @default(MANUAL)
  isActive        Boolean         @default(true)

  // Step 4 fields
  vatPercent     Decimal? // e.g. 15.00 for Saudi, 0.00 for Global
  legalInfo      Json?
  // legalInfo shape: { companyName, companyNameAr, tagline, taglineAr,
  //   crNumber, vatNumber, address, addressAr, phone, email, website,
  //   footerText, defaultPaymentTerms, quotationValidityDays,
  //   bankDetails: { bankName, accountName, iban, swift, currency } }
  companyProfile Json?
  // companyProfile shape: { logoUrl, primaryColor }
  paymentMethods String[] // ["BANK_TRANSFER", "STRIPE"]

  // Step 10 — Stripe per market
  stripePublicKey String?  // Stripe publishable key (safe to expose to client)
  stripeSecretKey String?  // Stripe secret key — NEVER expose in client responses
  showPayOnline   Boolean  @default(false) // show Pay Online button on documents

  users                    User[]
  subscriptions            Subscription[]
  pricing                  Pricing[]
  customerPricingOverrides CustomerPricingOverride[]
  pendingSignups           PendingSignup[]
  salesDocuments           SalesDocument[]
  numberSeries             NumberSeries[]
  payments                 SalesPayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
  @@index([isActive])
}

model CustomerGroup {
  id       String  @id @default(cuid())
  key      String  @unique
  name     String
  isActive Boolean @default(true)

  users   User[]
  pricing Pricing[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([key])
}

model User {
  id             String @id @default(cuid())
  customerNumber Int    @unique @default(autoincrement())
  email          String @unique
  role           Role   @default(CUSTOMER)

  marketId String
  market   Market @relation(fields: [marketId], references: [id], onDelete: Restrict)

  customerGroupId String?
  customerGroup   CustomerGroup? @relation(fields: [customerGroupId], references: [id], onDelete: SetNull)

  fullName    String?
  mobile      String?
  accountType AccountType?

  country  String?
  province String?

  companyName                  String?
  vatTaxId                     String?
  commercialRegistrationNumber String?

  addressLine1 String?
  addressLine2 String?
  district     String?
  city         String?
  buildingNumber  String?   // Saudi only — WASL/National Address building number
  secondaryNumber String?   // Saudi only — WASL/National Address secondary number
  postalCode      String?   // all markets — postal/zip code
  shortAddressCode String?  // business info — Saudi National Address short code e.g. RNAD2323
  tags         Tag[] // many-to-many (implicit)

  tcAccepted        Boolean?
  privacyAccepted   Boolean?
  marketingAccepted Boolean?

  sessions Session[]
  
  subscriptions         Subscription[]
  approvedSubscriptions Subscription[] @relation("SubscriptionApprovedBy")
  statusLogEntries      SubscriptionStatusLog[] @relation("StatusLogChangedBy")
  renewalEntries        SubscriptionRenewal[]   @relation("RenewalCreatedBy")
  documentLogs SalesDocumentLog[] @relation("DocumentLogChanger")

  servers   Server[]
  auditLogs AuditLog[]

  customerPricingOverrides CustomerPricingOverride[]

  notePublic  String? @db.Text
  notePrivate String? @db.Text

  // Step 4
  salesDocuments   SalesDocument[]
  assignedLeads    SalesDocument[] @relation("AssignedLeads")
  assignedActivities CRMActivity[] @relation("ActivityAssignee")
  createdActivities  CRMActivity[] @relation("ActivityCreator")
  notifications  Notification[]

  // Step 9 — Notification preferences
  notifPrefs Json?   // { "INVOICE_ISSUED": { email: true, sms: false, inapp: true }, ... }
  timezone   String? // IANA e.g. "Asia/Riyadh"
  dndStart   Int?    // DND hour start 0-23
  dndEnd     Int?    // DND hour end   0-23

  // Step 9 — Broadcasts created by this admin
  broadcastsCreated NotificationBroadcast[] @relation("BroadcastCreatedBy")

  createdAt DateTime @default(now())

  @@index([marketId])
  @@index([customerGroupId])
  @@index([role])
}

model PendingSignup {
  id    String @id @default(cuid())
  email String @unique

  marketId String
  market   Market @relation(fields: [marketId], references: [id], onDelete: Cascade)

  fullName    String?
  mobile      String?
  accountType AccountType?

  country  String?
  province String?

  companyName                  String?
  vatTaxId                     String?
  commercialRegistrationNumber String?

  addressLine1 String?
  addressLine2 String?
  district     String?
  city         String?
  buildingNumber  String?
  secondaryNumber String?
  postalCode      String?
  shortAddressCode String?

  tcAccepted        Boolean?
  privacyAccepted   Boolean?
  marketingAccepted Boolean?

  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expiresAt])
  @@index([marketId])
}

model LoginOtp {
  id           String    @id @default(cuid())
  email        String
  codeHash     String
  expiresAt    DateTime
  consumedAt   DateTime?
  attemptCount Int

  createdAt DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
}

model Session {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  token String @unique

  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Category {
  id       String  @id @default(cuid())
  key      String  @unique
  name     String
  nameAr   String? // NEW Step 4 — Arabic name
  isActive Boolean @default(true)

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tag {
  id   String @id @default(cuid())
  key  String @unique
  name String

  products Product[]
  users    User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}

model Product {
  id       String      @id @default(cuid())
  type     ProductType
  key      String      @unique
  name     String
  nameAr   String?     // NEW Step 4 — Arabic product name
  productDetails  String? @db.Text  // NEW Step 4 — EN marketing details (shown to customers)
  detailsAr       String? @db.Text  // NEW Step 4 — Arabic details
  isActive Boolean @default(true)

  billingPeriods BillingPeriod[]
  unitLabel      String?

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  zohoPlanId String?

  tags                     Tag[]
  pricing                  Pricing[]
  subscriptions            Subscription[]
  customerPricingOverrides CustomerPricingOverride[]

  // NEW Step 4
  salesDocumentLines SalesDocumentLine[]

  addonPricingType AddonPricingType?
  addonBehavior    AddonBehavior?
  applicableTags   String[]
  addonUnitLabel   String?
  addonMinUnits    Int?
  addonMaxUnits    Int?
  addonPercentage  Decimal?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([categoryId])
  @@index([isActive])
}

model Pricing {
  id              String         @id @default(cuid())
  productId       String
  product         Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  marketId        String
  market          Market         @relation(fields: [marketId], references: [id], onDelete: Cascade)
  customerGroupId String?
  customerGroup   CustomerGroup? @relation(fields: [customerGroupId], references: [id], onDelete: SetNull)
  billingPeriod   BillingPeriod
  priceCents      Int
  isActive        Boolean        @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, marketId, customerGroupId, billingPeriod])
  @@index([productId])
  @@index([marketId])
  @@index([customerGroupId])
}

model CustomerPricingOverride {
  id            String        @id @default(cuid())
  productId     String
  product       Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  marketId      String
  market        Market        @relation(fields: [marketId], references: [id], onDelete: Cascade)
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  billingPeriod BillingPeriod
  priceCents    Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, marketId, userId, billingPeriod])
  @@index([userId])
  @@index([productId])
}

model Subscription {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  marketId String
  market   Market @relation(fields: [marketId], references: [id], onDelete: Restrict)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  quantity     Int?
  templateSlug String?
  locationCode String?

  status SubscriptionStatus @default(PENDING_PAYMENT)

  parentSubscriptionId String?
  parentSubscription   Subscription?  @relation("AddonParent", fields: [parentSubscriptionId], references: [id], onDelete: SetNull)
  childSubscriptions   Subscription[] @relation("AddonParent")

  billingPeriod BillingPeriod @default(YEARLY)
  paymentStatus PaymentStatus @default(UNPAID)

  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?

  autoRenew              Boolean   @default(false)  // auto-renew on expiry
  renewalBillingPeriod   BillingPeriod?            // if set, overrides billingPeriod on renewal
  renewalPriceCents      Int?                      // if set, overrides catalog price on renewal

  invoiceNumber          String?
  receiptUrl             String?
  receiptFileName        String?
  receiptUploadedAt      DateTime?
  manualPaymentReference String?

  productDetails String?
  productNote    String?

  approvedByUserId String?
  approvedBy       User?   @relation("SubscriptionApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)

  zohoSubscriptionId String?

  servers    Server[]
  statusLogs SubscriptionStatusLog[]
  renewals   SubscriptionRenewal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([marketId])
  @@index([productId])
  @@index([parentSubscriptionId])
  @@index([approvedByUserId])
}

// ── Subscription Renewal Log ─────────────────────────────────────────────────
model SubscriptionRenewal {
  id             String   @id @default(cuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  // Period for this renewal
  periodStart    DateTime
  periodEnd      DateTime
  billingPeriod  BillingPeriod

  // Pricing snapshot at time of renewal
  priceCents     Int               // plan price
  addonsCents    Int      @default(0) // total addons price
  totalCents     Int               // grand total
  currency       String

  // Override price (admin set)
  overrideCents  Int?              // if set, used instead of catalog price
  overrideNote   String?

  // Addon subscriptions renewed (comma-separated IDs stored as JSON)
  renewedAddonIds String  @default("[]")

  isAutomatic    Boolean  @default(false)
  notes          String?  @db.Text

  renewedByUserId String?
  renewedBy       User?   @relation("RenewalCreatedBy", fields: [renewedByUserId], references: [id], onDelete: SetNull)

  // Step 5: link to SalesDocument invoice when generated
  salesDocumentId String?

  createdAt DateTime @default(now())

  @@index([subscriptionId])
  @@index([createdAt])
}

// ── Subscription Status Log ───────────────────────────────────────────────────
model SubscriptionStatusLog {
  id             String             @id @default(cuid())
  subscriptionId String
  subscription   Subscription       @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  status         SubscriptionStatus // the new status set
  comment        String             @db.Text
  isAutomatic    Boolean            @default(false) // true = system triggered

  changedByUserId String?
  changedBy       User?   @relation("StatusLogChangedBy", fields: [changedByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([subscriptionId])
  @@index([createdAt])
}

model Server {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  subscriptionId String?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  hetznerServerId      String? @unique
  hetznerApiToken      String?
  oracleInstanceId     String? @unique
  oracleInstanceRegion  String?
  oracleCompartmentOcid String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([subscriptionId])
}

model OsTemplate {
  id          String           @id @default(cuid())
  slug        String           @unique
  name        String
  family      String?
  description String?
  category    String
  iconType    TemplateIconType @default(devicon)
  iconValue   String?
  status      TemplateStatus   @default(active)
  sortOrder   Int              @default(1)
  isDefault   Boolean          @default(false)
  tagKeys     String[]    // legacy — kept for backward compat
  includeTags String[]    // products with ANY of these tags appear with this template
  excludeTags String[]    // products with ANY of these tags are hidden, even if they match includeTags

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([family])
  @@index([category])
}

model Location {
  id          String         @id @default(cuid())
  code        String         @unique
  name        String
  family      String?
  description String?
  countryCode String?
  flag        String?
  status      LocationStatus @default(active)
  sortOrder   Int            @default(1)
  isDefault   Boolean        @default(false)
  includeTags String[]
  excludeTags String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([family])
}

model AuditLog {
  id          String @id @default(cuid())
  actorUserId String
  actor       User   @relation(fields: [actorUserId], references: [id], onDelete: Cascade)

  action       String
  entityType   String
  entityId     String
  metadataJson String?

  createdAt DateTime @default(now())

  @@index([actorUserId])
  @@index([entityType, entityId])
}

//////////////////////////////////////////////////////
// NEW MODELS — Step 4
//////////////////////////////////////////////////////

// ── Number Series ─────────────────────────────────────────────────────────────
// Saudi prefix "CY", starts 5250 | Global prefix "CYB", starts 10250
// One row per market × doc type. nextNum auto-increments on each use.
model NumberSeries {
  id       String            @id @default(cuid())
  marketId String
  market   Market            @relation(fields: [marketId], references: [id], onDelete: Cascade)
  docType  SalesDocumentType
  prefix   String            // e.g. "CY-INV" or "CYB-INV"
  nextNum  Int               // next number to allocate

  updatedAt DateTime @updatedAt

  @@unique([marketId, docType])
  @@index([marketId])
}

// ── Sales Document ────────────────────────────────────────────────────────────
model SalesDocument {
  id     String              @id @default(cuid())
  docNum String              @unique // e.g. "CY-INV-5250"
  type   SalesDocumentType
  status SalesDocumentStatus @default(DRAFT)

  marketId String
  market   Market @relation(fields: [marketId], references: [id], onDelete: Restrict)

  customerId String
  customer   User   @relation(fields: [customerId], references: [id], onDelete: Restrict)

  // Document chain — links derived docs back to origin
  originDocId String?
  originDoc   SalesDocument?  @relation("DocChain", fields: [originDocId], references: [id], onDelete: SetNull)
  derivedDocs SalesDocument[] @relation("DocChain")

  currency     String  // "SAR" or "USD"
  subtotal     Int     @default(0) // cents
  vatPercent   Decimal @default(0)
  vatAmount    Int     @default(0) // cents
  total        Int     @default(0) // cents
  manualSent Boolean? @default(false)

  subject            String?
  referenceNumber    String?
  notes              String? @db.Text
  internalNote       String? @db.Text
  termsAndConditions String? @db.Text

  language String @default("en") // "en" | "ar" | "bi"

  // Email tracking
  emailSentAt    DateTime?
  emailSentCount Int       @default(0)

  issueDate  DateTime  @default(now())
  dueDate    DateTime?
  validUntil DateTime? // quotation expiry
  paidAt     DateTime?

  // RFQ-specific
  rfqTitle   String?
  rfqFileUrl String? // S3 URL of attached file

  // Saudi e-Invoice Phase 1 QR
  zatcaQrCode String?

  // CRM / Lead fields (RFQ only)
  leadSource        String?   // PORTAL | MANUAL | REFERRAL | EMAIL | PHONE | OTHER
  leadPriority      String?   // LOW | MEDIUM | HIGH | URGENT
  assignedToId      String?
  assignedTo        User?     @relation("AssignedLeads", fields: [assignedToId], references: [id], onDelete: SetNull)
  expectedCloseDate DateTime?
  followUpDate      DateTime?
  lostReason        String?

  pdfKey            String?

  activities CRMActivity[]

  // Invoice reminder — weekly automated reminders, up to 4 times
  // Only applies to INVOICE type with unpaid status (ISSUED / SENT / PARTIAL / OVERDUE)
  reminderEnabled    Boolean   @default(false)
  reminderCount      Int       @default(0)       // how many reminders sent so far (max 4)
  reminderLastSentAt DateTime?                   // when last reminder was sent

  lines    SalesDocumentLine[]
  payments SalesPayment[]
  logs SalesDocumentLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([marketId])
  @@index([customerId])
  @@index([type])
  @@index([status])
  @@index([issueDate])
  @@index([emailSentAt])
  @@index([validUntil])
  @@index([reminderEnabled])
}

model SalesDocumentLog {
  id         String        @id @default(cuid())
  documentId String
  document   SalesDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  field      String
  oldValue   String?
  newValue   String?
  note       String?       @db.Text
  changedById String
  changedBy   User         @relation("DocumentLogChanger", fields: [changedById], references: [id], onDelete: Restrict)
  createdAt  DateTime      @default(now())
  @@index([documentId])
}

model CRMActivity {
  id          String    @id @default(cuid())
  documentId  String
  document    SalesDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  type        String    // CALL | MEETING | TASK | NOTE
  title       String
  description String?   @db.Text
  dueDate     DateTime?
  completedAt DateTime?

  assignedToId     String?
  assignedTo       User?   @relation("ActivityAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdByAdminId String?
  createdBy        User?   @relation("ActivityCreator", fields: [createdByAdminId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([documentId])
  @@index([dueDate])
  @@index([assignedToId])
}

// ── Sales Document Line ───────────────────────────────────────────────────────
model SalesDocumentLine {
  id         String        @id @default(cuid())
  documentId String
  document   SalesDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  description   String
  descriptionAr String? // Arabic name override for this line only
  billingPeriod String? // MONTHLY | SIX_MONTHS | YEARLY | ONE_TIME | null
  productDetails String? @db.Text // EN details override for this line only
  detailsAr      String? @db.Text // AR details override for this line only
  quantity    Decimal @default(1)
  unitPrice   Int     // cents
  discount    Decimal @default(0) // percentage 0–100
  lineTotal   Int     // cents, after discount
  sortOrder   Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([documentId])
  @@index([productId])
}

// ── Sales Payment ─────────────────────────────────────────────────────────────
// Named SalesPayment to avoid conflict with PaymentStatus enum
model SalesPayment {
  id         String        @id @default(cuid())
  documentId String
  document   SalesDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  marketId String
  market   Market @relation(fields: [marketId], references: [id], onDelete: Restrict)

  method      PaymentMethod
  amountCents Int
  currency    String
  reference   String? // bank ref, Stripe charge ID
  notes       String?
  receiptUrl  String? // S3 URL
  paidAt      DateTime @default(now())

  createdAt DateTime @default(now())

  @@index([documentId])
  @@index([marketId])
}

// ── Notification ──────────────────────────────────────────────────────────────
model Notification {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type  NotificationType @default(INFO)
  title String
  body  String           @db.Text
  link  String? // optional deep link e.g. /dashboard/invoices/CY-INV-5250

  isRead Boolean   @default(false)
  readAt DateTime?

  emailSent   Boolean   @default(false)
  emailSentAt DateTime?

  // Step 9
  eventType      String?
  channel        String?
  smsSent        Boolean   @default(false)
  smsSentAt      DateTime?
  smsDelivered   Boolean   @default(false)
  emailDelivered Boolean   @default(false)
  retryCount     Int       @default(0)
  failureReason  String?
  broadcastId    String?
  scheduledAt    DateTime?
  sentAt         DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@index([eventType])
  @@index([broadcastId])
  @@index([channel])
}

// ── Portal Page (CMS) ─────────────────────────────────────────────────────────
model PortalPage {
  id        String  @id @default(cuid())
  slug      String  @unique // e.g. "terms", "privacy", "about"
  title     String
  titleAr   String?
  content   String  @db.Text
  contentAr String? @db.Text
  isPublic  Boolean @default(true)
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([isPublic])
}

// ── Portal Settings ───────────────────────────────────────────────────────────
// Generic key-value store for all admin-configurable settings
// Key examples: "smtp.host", "smtp.port", "smtp.user", "smtp.pass",
//               "portal.name", "portal.logoUrl", "portal.supportEmail"
model PortalSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text

  updatedAt DateTime @updatedAt

  @@index([key])
}


//////////////////////////////////////////////////////
// Step 9 — Notification System
//////////////////////////////////////////////////////

model NotificationTemplate {
  id           String  @id @default(cuid())
  eventType    String  @unique
  name         String
  emailSubject String  @default("")
  emailBody    String  @db.Text @default("")
  smsBody      String?
  defaultEmail Boolean @default(true)
  defaultSms   Boolean @default(false)
  defaultInapp Boolean @default(true)
  lockChannels Boolean @default(false)
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([eventType])
  @@index([isActive])
}

model NotificationBroadcast {
  id            String   @id @default(cuid())
  title         String
  body          String   @db.Text
  emailSubject  String?
  smsBody       String?
  broadcastType String   @default("ESSENTIAL") // "ESSENTIAL" | "MARKETING"
  channels      String[]
  targetType    String   // "customer" | "group" | "market" | "tag" | "all"
  targetId      String?

  scheduledAt DateTime?
  sentAt      DateTime?
  totalCount  Int @default(0)
  sentCount   Int @default(0)
  failCount   Int @default(0)

  createdByUserId String
  createdBy       User   @relation("BroadcastCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([sentAt])
  @@index([targetType])
  @@index([broadcastType])
}
