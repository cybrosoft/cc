// prisma/schema-notification-patch.prisma
// ADD these fields to existing models in prisma/schema.prisma
// All fields are optional — zero breaking changes.

// ── Add to User model ─────────────────────────────────────────────────────────
// After the existing `notifications  Notification[]` line, add:

//   // Notification preferences — per event type channel toggles
//   // Structure: { "INVOICE_ISSUED": { email: true, sms: false, inapp: true }, ... }
//   notifPrefs Json?
//   timezone   String? // IANA timezone e.g. "Asia/Riyadh", "America/New_York"
//   dndStart   Int?    // DND hour start 0-23 (e.g. 22 = 10pm) — SMS blocked in this window
//   dndEnd     Int?    // DND hour end   0-23 (e.g. 8  = 8am)

// ── Add to Notification model ─────────────────────────────────────────────────
// After the existing `emailSentAt DateTime?` line, add:

//   eventType      String?   // INVOICE_ISSUED | SUB_EXPIRING | PAYMENT_RECEIVED | etc.
//   channel        String?   // "inapp" | "email" | "sms"
//   smsSent        Boolean   @default(false)
//   smsSentAt      DateTime?
//   smsDelivered   Boolean   @default(false)
//   emailDelivered Boolean   @default(false)
//   retryCount     Int       @default(0)
//   failureReason  String?
//   broadcastId    String?   // groups notifications from same broadcast
//   scheduledAt    DateTime? // null = send immediately
//   sentAt         DateTime? // when actually dispatched
//
//   @@index([eventType])
//   @@index([broadcastId])
//   @@index([channel])

// ── New models to ADD to schema.prisma ───────────────────────────────────────

model NotificationTemplate {
  id           String  @id @default(cuid())
  eventType    String  @unique // system key — not editable by admin
  name         String           // display name
  emailSubject String  @default("")
  emailBody    String  @db.Text @default("")  // HTML, supports {variables}
  smsBody      String?          // plain text, short, supports {variables}
  defaultEmail Boolean @default(true)
  defaultSms   Boolean @default(false)
  defaultInapp Boolean @default(true)
  lockChannels Boolean @default(false) // if true, customer cannot override
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([eventType])
  @@index([isActive])
}

model NotificationBroadcast {
  id           String  @id @default(cuid())
  title        String
  body         String  @db.Text
  emailSubject String?
  smsBody      String?
  channels     String[] // ["inapp", "email", "sms"]
  targetType   String   // "customer" | "group" | "market" | "all"
  targetId     String?  // userId | groupId | marketId (null for "all")

  scheduledAt DateTime?
  sentAt      DateTime?
  totalCount  Int @default(0)
  sentCount   Int @default(0)
  failCount   Int @default(0)

  createdByUserId String
  createdBy       User   @relation("BroadcastCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([sentAt])
  @@index([targetType])
}
